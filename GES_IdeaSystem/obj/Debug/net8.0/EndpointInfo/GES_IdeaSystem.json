                  "AttachmentPath": {
                    "type": "string"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "Title": {
                  "style": "form"
                },
                "Type": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "GESCenterId": {
                  "style": "form"
                },
                "ContributorId": {
                  "style": "form"
                },
                "CoContributors": {
                  "style": "form"
                },
                "AttachmentPath": {
                  "style": "form"
                },
                "file": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
